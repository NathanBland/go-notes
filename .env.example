APP_ENV=development
HTTP_ADDR=:8080
BASE_URL=http://localhost:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/go_notes?sslmode=disable
VALKEY_ADDR=127.0.0.1:6379
VALKEY_PASSWORD=
SESSION_COOKIE_NAME=go_notes_session
SESSION_TTL=168h
OIDC_STATE_TTL=5m
NOTE_CACHE_TTL=5m
LIST_CACHE_TTL=45s
THROTTLE_REQUESTS_PER_SECOND=2
THROTTLE_BURST=5

# External OIDC provider settings. The issuer URL should be the provider's
# issuer root, not the .well-known URL. go-oidc uses this value for discovery.
OIDC_ISSUER_URL=https://your-provider.example/realms/go-notes
OIDC_CLIENT_ID=go-notes

# Leave blank for public clients that rely on PKCE only. Set a real secret for
# confidential clients if your provider requires it.
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback
OIDC_SCOPES=openid,profile,email

# Set this to true when the app is served behind HTTPS so browsers will keep
# the session cookie on secure requests only.
SESSION_COOKIE_SECURE=false

# Local MCP configuration. This first MCP slice uses a fixed owner UUID for
# local development until the project adds a fuller MCP-specific auth story.
MCP_OWNER_USER_ID=

# Production image override for registry-backed deployments. Pin this to a
# release tag in real environments instead of relying on latest.
GO_NOTES_IMAGE=ghcr.io/nathanbland/go-notes:latest
