APP_ENV=production
PUBLIC_HTTP_PORT=8080
BASE_URL=https://notes.example.com
POSTGRES_DB=go_notes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
VALKEY_PASSWORD=
SESSION_COOKIE_NAME=go_notes_session
SESSION_TTL=168h
OIDC_STATE_TTL=5m
NOTE_CACHE_TTL=5m
LIST_CACHE_TTL=45s
THROTTLE_REQUESTS_PER_SECOND=2
THROTTLE_BURST=5
OIDC_ISSUER_URL=https://cloak.example.com/realms/lab
OIDC_CLIENT_ID=go-notes
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=https://notes.example.com/api/v1/auth/callback
OIDC_SCOPES=openid,profile,email
SESSION_COOKIE_SECURE=true
GO_NOTES_IMAGE=ghcr.io/nathanbland/go-notes:latest
